{
  "name": "backstop",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api & npm run dev:operator & npm run dev:owner",
    "dev:api": "npm run dev -w @backstop/api",
    "dev:operator": "npm run dev -w @backstop/operator",
    "dev:owner": "npm run dev -w @backstop/owner",
    "dev:legacy": "next dev",
    "build": "next build",
    "build:apps": "npm run build -w @backstop/operator && npm run build -w @backstop/owner",
    "start": "next start",
    "lint": "next lint",
    "test": "tsx --test src/lib/csv/parse-claims-csv.test.ts src/lib/csv/parse-outcomes-csv.test.ts src/lib/rules/scrub-claim.test.ts packages/events/src/projectors.test.ts",
    "test:seed": "tsx --env-file=.env --test scripts/seed-rls.test.ts",
    "test:events": "tsx --env-file=.env --test scripts/events-replay.test.ts",
    "seed": "tsx --env-file=.env scripts/seed-synthetic.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
