{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@backstop/auth": ["../../packages/auth/src/index.ts"],
      "@backstop/db": ["../../packages/db/src/index.ts"]
    }
  },
  "include": ["src"]
}
