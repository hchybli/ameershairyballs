# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Vite apps (operator, owner) — browser-safe publishable key only
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-side only (seed scripts, edge functions, API) — NEVER expose to browser
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Legacy Next.js app (src/) — optional until legacy is removed
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Future phases — leave blank for now
# ANTHROPIC_API_KEY=
# RESEND_API_KEY=
